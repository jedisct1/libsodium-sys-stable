sha3512-bytes: func() -> u32

/// Compute SHA-3-512 hash
sha3512-hash: func(message: list<u8>) -> list<u8>

// ============================================================================
// Auth - Secret-key authentication (HMAC-SHA512-256)
// ============================================================================

