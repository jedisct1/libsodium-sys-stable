auth-bytes: func() -> u32

/// Key size in bytes (32)
auth-key-bytes: func() -> u32

/// Generate a random key
auth-keygen: func() -> list<u8>

/// Compute an authentication tag
auth-auth: func(message: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// Verify an authentication tag
auth-verify: func(tag: list<u8>, message: list<u8>, key: list<u8>) -> expected<unit, crypto-error>

