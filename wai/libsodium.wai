kdf-context-bytes: func() -> u32

/// Minimum derived key size (16)
kdf-bytes-min: func() -> u32

/// Maximum derived key size (64)
kdf-bytes-max: func() -> u32

/// Primitive name ("blake2b")
kdf-primitive: func() -> string

/// Generate a master key
kdf-keygen: func() -> list<u8>

