kdf-hkdf-sha256-extract: func(salt: list<u8>, ikm: list<u8>) -> expected<list<u8>, crypto-error>

/// Initialize incremental extraction state
kdf-hkdf-sha256-extract-init: func(salt: list<u8>) -> expected<u64, crypto-error>

/// Update extraction state with input keying material
kdf-hkdf-sha256-extract-update: func(state-id: u64, ikm: list<u8>) -> expected<unit, crypto-error>

/// Finalize extraction and return PRK
kdf-hkdf-sha256-extract-final: func(state-id: u64) -> expected<list<u8>, crypto-error>

/// Expand a PRK to derived keys
kdf-hkdf-sha256-expand: func(out-len: u32, prk: list<u8>, info: list<u8>) -> expected<list<u8>, crypto-error>

