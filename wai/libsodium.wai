// libsodium cryptographic library - WAI interface for Wasmer
// This provides safe wrappers around libsodium's functionality
// Auto-generated from WIT definitions

/// Result type for cryptographic operations
variant crypto-error {
    /// Operation failed (invalid input, verification failure, etc.)
    operation-failed,
    /// Invalid key size
    invalid-key-size,
    /// Invalid nonce size
    invalid-nonce-size,
    /// Message too long
    message-too-long,
    /// Decryption/verification failed
    verification-failed,
    /// Library not initialized
    not-initialized,
}

/// Key pair for public-key cryptography
record key-pair {
    public-key: list<u8>,
    secret-key: list<u8>,
}

/// Key pair for signing operations
record sign-key-pair {
    public-key: list<u8>,
    secret-key: list<u8>,
}

/// Key pair for key exchange
record kx-key-pair {
    public-key: list<u8>,
    secret-key: list<u8>,
}

/// Session keys from key exchange
record session-keys {
    rx: list<u8>,
    tx: list<u8>,
}

// ============================================================================
// Core - Library initialization and version information
// ============================================================================

/// Initialize the library. Must be called before any other function.
/// Returns 0 on success, 1 if already initialized, -1 on failure.
init: func() -> s32

/// Get the library version string
version-string: func() -> string

/// Get the major version number
library-version-major: func() -> s32

/// Get the minor version number
library-version-minor: func() -> s32

// ============================================================================
// Random - Secure random number generation
// ============================================================================

/// Generate random bytes
random-bytes: func(len: u32) -> list<u8>

/// Generate a random 32-bit unsigned integer
random-u32: func() -> u32

/// Generate a random 32-bit unsigned integer in range [0, upper_bound)
random-uniform: func(upper-bound: u32) -> u32

// ============================================================================
// Secretbox - Secret-key authenticated encryption (XSalsa20-Poly1305)
// ============================================================================

/// Key size in bytes (32)
secretbox-key-bytes: func() -> u32

/// Nonce size in bytes (24)
secretbox-nonce-bytes: func() -> u32

/// Authentication tag size in bytes (16)
secretbox-mac-bytes: func() -> u32

/// Generate a random key
secretbox-keygen: func() -> list<u8>

/// Encrypt and authenticate a message
/// Returns ciphertext (message + mac)
secretbox-easy: func(message: list<u8>, nonce: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// Decrypt and verify a message
/// Returns plaintext on success
secretbox-open-easy: func(ciphertext: list<u8>, nonce: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// Encrypt with detached authentication tag
secretbox-detached: func(message: list<u8>, nonce: list<u8>, key: list<u8>) -> expected<tuple<list<u8>, list<u8>>, crypto-error>

/// Decrypt with detached authentication tag
secretbox-open-detached: func(ciphertext: list<u8>, mac: list<u8>, nonce: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
// Crypto Box - Public-key authenticated encryption (X25519-XSalsa20-Poly1305)
// ============================================================================

/// Public key size in bytes (32)
crypto-box-public-key-bytes: func() -> u32

/// Secret key size in bytes (32)
crypto-box-secret-key-bytes: func() -> u32

/// Nonce size in bytes (24)
crypto-box-nonce-bytes: func() -> u32

/// Authentication tag size in bytes (16)
crypto-box-mac-bytes: func() -> u32

/// Seed size in bytes (32)
crypto-box-seed-bytes: func() -> u32

/// Precomputed shared key size in bytes (32)
crypto-box-beforenm-bytes: func() -> u32

/// Generate a random key pair
crypto-box-keypair: func() -> key-pair

/// Generate a key pair from a seed
crypto-box-seed-keypair: func(seed: list<u8>) -> expected<key-pair, crypto-error>

/// Encrypt and authenticate a message for a recipient
crypto-box-easy: func(message: list<u8>, nonce: list<u8>, recipient-pk: list<u8>, sender-sk: list<u8>) -> expected<list<u8>, crypto-error>

/// Decrypt and verify a message from a sender
crypto-box-open-easy: func(ciphertext: list<u8>, nonce: list<u8>, sender-pk: list<u8>, recipient-sk: list<u8>) -> expected<list<u8>, crypto-error>

/// Encrypt with detached authentication tag
crypto-box-detached: func(message: list<u8>, nonce: list<u8>, recipient-pk: list<u8>, sender-sk: list<u8>) -> expected<tuple<list<u8>, list<u8>>, crypto-error>

/// Decrypt with detached authentication tag
crypto-box-open-detached: func(ciphertext: list<u8>, mac: list<u8>, nonce: list<u8>, sender-pk: list<u8>, recipient-sk: list<u8>) -> expected<list<u8>, crypto-error>

/// Precompute a shared secret for efficiency
crypto-box-beforenm: func(recipient-pk: list<u8>, sender-sk: list<u8>) -> expected<list<u8>, crypto-error>

/// Encrypt using a precomputed shared secret
crypto-box-easy-afternm: func(message: list<u8>, nonce: list<u8>, shared-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Decrypt using a precomputed shared secret
crypto-box-open-easy-afternm: func(ciphertext: list<u8>, nonce: list<u8>, shared-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Encrypt with detached tag using precomputed shared secret
crypto-box-detached-afternm: func(message: list<u8>, nonce: list<u8>, shared-key: list<u8>) -> expected<tuple<list<u8>, list<u8>>, crypto-error>

/// Decrypt with detached tag using precomputed shared secret
crypto-box-open-detached-afternm: func(ciphertext: list<u8>, mac: list<u8>, nonce: list<u8>, shared-key: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
// Seal - Anonymous public-key encryption (sealed boxes)
// ============================================================================

/// Additional bytes added to the ciphertext (48)
seal-bytes: func() -> u32

/// Encrypt a message anonymously for a recipient
seal-seal: func(message: list<u8>, recipient-pk: list<u8>) -> expected<list<u8>, crypto-error>

/// Decrypt an anonymous message
seal-open: func(ciphertext: list<u8>, recipient-pk: list<u8>, recipient-sk: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
// Sign - Public-key signatures (Ed25519)
// ============================================================================

/// Public key size in bytes (32)
sign-public-key-bytes: func() -> u32

/// Secret key size in bytes (64)
sign-secret-key-bytes: func() -> u32

/// Signature size in bytes (64)
sign-signature-bytes: func() -> u32

/// Seed size in bytes (32)
sign-seed-bytes: func() -> u32

/// State size in bytes for multi-part operations
sign-state-bytes: func() -> u32

/// Generate a random signing key pair
sign-keypair: func() -> sign-key-pair

/// Generate a signing key pair from a seed
sign-seed-keypair: func(seed: list<u8>) -> expected<sign-key-pair, crypto-error>

/// Sign a message (returns signature + message)
sign-sign: func(message: list<u8>, secret-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Verify and extract a signed message
sign-open: func(signed-message: list<u8>, public-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Create a detached signature
sign-detached: func(message: list<u8>, secret-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Verify a detached signature
sign-verify-detached: func(signature: list<u8>, message: list<u8>, public-key: list<u8>) -> expected<unit, crypto-error>

/// Initialize multi-part signature state (Ed25519ph)
/// Returns state-id
sign-init: func() -> expected<u64, crypto-error>

/// Update signature state with more data
sign-update: func(state-id: u64, message: list<u8>) -> expected<unit, crypto-error>

/// Finalize and create signature from multi-part message
sign-final-create: func(state-id: u64, secret-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Finalize and verify signature for multi-part message
sign-final-verify: func(state-id: u64, signature: list<u8>, public-key: list<u8>) -> expected<unit, crypto-error>

/// Destroy a signature state
sign-destroy: func(state-id: u64)

/// Extract the public key from a secret key
sign-ed25519-sk-to-pk: func(secret-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Extract the seed from a secret key
sign-ed25519-sk-to-seed: func(secret-key: list<u8>) -> expected<list<u8>, crypto-error>

/// Convert Ed25519 public key to X25519
sign-ed25519-pk-to-curve25519: func(ed25519-pk: list<u8>) -> expected<list<u8>, crypto-error>

/// Convert Ed25519 secret key to X25519
sign-ed25519-sk-to-curve25519: func(ed25519-sk: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
// Generichash - Generic hashing (BLAKE2b)
// ============================================================================

/// Default hash size in bytes (32)
generichash-bytes: func() -> u32

/// Minimum hash size (16)
generichash-bytes-min: func() -> u32

/// Maximum hash size (64)
generichash-bytes-max: func() -> u32

/// Default key size (32)
generichash-key-bytes: func() -> u32

/// Minimum key size (16)
generichash-key-bytes-min: func() -> u32

/// Maximum key size (64)
generichash-key-bytes-max: func() -> u32

/// Generate a random key
generichash-keygen: func() -> list<u8>

/// Hash a message without a key
generichash-hash: func(message: list<u8>, out-len: u32) -> expected<list<u8>, crypto-error>

/// Hash a message with a key
generichash-hash-keyed: func(message: list<u8>, out-len: u32, key: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
