// ============================================================================
// Pwhash - Password hashing (Argon2)
// ============================================================================

/// Salt size in bytes (16)
pwhash-salt-bytes: func() -> u32

/// Encoded hash string size (128)
pwhash-str-bytes: func() -> u32

/// Minimum output size (16)
pwhash-bytes-min: func() -> u32

/// Maximum output size
pwhash-bytes-max: func() -> u32

/// Minimum password length (0)
pwhash-passwd-min: func() -> u32

/// Maximum password length
pwhash-passwd-max: func() -> u32

/// Minimum ops limit
pwhash-opslimit-min: func() -> u64

/// Maximum ops limit
pwhash-opslimit-max: func() -> u64

/// Interactive ops limit (for online operations)
pwhash-opslimit-interactive: func() -> u64

/// Moderate ops limit
pwhash-opslimit-moderate: func() -> u64

/// Sensitive ops limit (for key derivation)
pwhash-opslimit-sensitive: func() -> u64

/// Minimum memory limit
pwhash-memlimit-min: func() -> u64

/// Maximum memory limit
pwhash-memlimit-max: func() -> u64

/// Interactive memory limit
pwhash-memlimit-interactive: func() -> u64

/// Moderate memory limit
pwhash-memlimit-moderate: func() -> u64

/// Sensitive memory limit
pwhash-memlimit-sensitive: func() -> u64

/// Algorithm: Argon2i 1.3
pwhash-alg-argon2i13: func() -> s32

/// Algorithm: Argon2id 1.3
pwhash-alg-argon2id13: func() -> s32

/// Default algorithm (Argon2id 1.3)
pwhash-alg-default: func() -> s32

/// Hash string prefix for algorithm identification
pwhash-strprefix: func() -> string

/// Derive a key from a password with algorithm selection
pwhash-derive: func(out-len: u32, password: list<u8>, salt: list<u8>, opslimit: u64, memlimit: u64, alg: s32) -> expected<list<u8>, crypto-error>

/// Hash a password to a string
pwhash-str: func(password: list<u8>, opslimit: u64, memlimit: u64) -> expected<string, crypto-error>

/// Verify a password against a hash string
pwhash-str-verify: func(hash: string, password: list<u8>) -> expected<unit, crypto-error>

/// Check if a hash needs rehashing
pwhash-str-needs-rehash: func(hash: string, opslimit: u64, memlimit: u64) -> expected<bool, crypto-error>

