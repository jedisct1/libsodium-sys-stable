/// Key size in bytes (16)
ipcrypt-key-bytes: func() -> u32

/// Generate a random 16-byte key for deterministic mode
ipcrypt-keygen: func() -> list<u8>

/// Deterministic encrypt: same input always produces same output
ipcrypt-encrypt: func(input: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// Deterministic decrypt
ipcrypt-decrypt: func(input: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// ND key size in bytes (16)
ipcrypt-nd-key-bytes: func() -> u32

/// ND tweak size in bytes (8)
ipcrypt-nd-tweak-bytes: func() -> u32

/// ND input size in bytes (16)
ipcrypt-nd-input-bytes: func() -> u32

/// ND output size in bytes (24 = 8-byte tweak + 16-byte ciphertext)
ipcrypt-nd-output-bytes: func() -> u32

/// ND encrypt: different output each time; tweak prepended to ciphertext
ipcrypt-nd-encrypt: func(input: list<u8>, tweak: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// ND decrypt: extracts tweak from ciphertext automatically
ipcrypt-nd-decrypt: func(ciphertext: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// NDX key size in bytes (32)
ipcrypt-ndx-key-bytes: func() -> u32

/// NDX tweak size in bytes (16)
ipcrypt-ndx-tweak-bytes: func() -> u32

/// NDX input size in bytes (16)
ipcrypt-ndx-input-bytes: func() -> u32

/// NDX output size in bytes (32)
ipcrypt-ndx-output-bytes: func() -> u32

/// Generate a random 32-byte key for NDX mode
ipcrypt-ndx-keygen: func() -> list<u8>

/// NDX encrypt: maximum security with 16-byte tweak
ipcrypt-ndx-encrypt: func(input: list<u8>, tweak: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// NDX decrypt
ipcrypt-ndx-decrypt: func(ciphertext: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// PFX key size in bytes (32)
ipcrypt-pfx-key-bytes: func() -> u32

/// PFX block size in bytes (16)
ipcrypt-pfx-bytes: func() -> u32

/// Generate a random 32-byte key for PFX mode
ipcrypt-pfx-keygen: func() -> list<u8>

/// PFX encrypt: preserves network prefix relationships
ipcrypt-pfx-encrypt: func(input: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

/// PFX decrypt
ipcrypt-pfx-decrypt: func(input: list<u8>, key: list<u8>) -> expected<list<u8>, crypto-error>

