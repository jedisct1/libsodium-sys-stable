/// Compute q = n * base point
scalarmult-base: func(n: list<u8>) -> expected<list<u8>, crypto-error>

// ============================================================================
// Utils - Secure memory utilities
// ============================================================================

/// Securely zero memory
utils-memzero: func(data: list<u8>) -> list<u8>

/// Constant-time memory comparison
utils-memcmp: func(a: list<u8>, b: list<u8>) -> expected<bool, crypto-error>

/// Increment a byte array as a little-endian number
utils-increment: func(data: list<u8>) -> list<u8>

/// Add two byte arrays as little-endian numbers
utils-add: func(a: list<u8>, b: list<u8>) -> expected<list<u8>, crypto-error>

/// Subtract two byte arrays as little-endian numbers
utils-sub: func(a: list<u8>, b: list<u8>) -> expected<list<u8>, crypto-error>

/// Compare two byte arrays as little-endian numbers
utils-compare: func(a: list<u8>, b: list<u8>) -> s32

/// Check if a byte array is all zeros
utils-is-zero: func(data: list<u8>) -> bool

/// Encode bytes to hexadecimal
utils-bin2hex: func(data: list<u8>) -> string

/// Decode hexadecimal to bytes
utils-hex2bin: func(hex: string) -> expected<list<u8>, crypto-error>

/// Decode hexadecimal to bytes, ignoring specified characters (e.g., ":" or " ")
